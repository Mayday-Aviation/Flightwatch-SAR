// ── EXPOSE TO WINDOW
async function writeLog(type,msg){
  try{ await addDoc(collection(db,'sar_logs'),{type,msg,time:localNow(),ts:serverTimestamp()}); }catch(e){}
}
window._writeLog=writeLog;

window.submitCheckin=async function(){
  if(!window._currentUser){ showToast('Please log in first','error'); return; }
  const pilot=document.getElementById('ci-pilot').value;
  const phone=document.getElementById('ci-phone').value;
  const regoFull=document.getElementById('ci-rego').value;
  const dep=document.getElementById('ci-dep').value.toUpperCase().trim();
  const dest=document.getElementById('ci-dest').value.toUpperCase().trim();
  const etd=document.getElementById('ci-etd').value;
  const eta=document.getElementById('ci-eta').value;
  const sartime=document.getElementById('ci-sartime').value;
  const pax=document.getElementById('ci-pax').value||'0';
  const type=document.getElementById('ci-type').value;
  const notes=document.getElementById('ci-notes').value;
  if(!pilot||!regoFull||!dep||!dest||!etd||!eta||!sartime){showToast('Fill in all required fields *','error');return;}
  // Pilots can only lodge flights as themselves
  if(window._currentUser.role==='pilot' && pilot!==window._currentUser.name){
    showToast('You can only lodge flights under your own name','error'); return;
  }
  const parts=regoFull.split(' — ');
  const rego=parts[0]; const aircraft=parts[1]||'';
  const btn=document.getElementById('submit-btn');
  btn.disabled=true; btn.textContent='Saving...';
  try{
    await addDoc(collection(db,'flights'),{
      pilot,phone,rego,aircraft,dep,dest,etd,eta,sartime,pax,type,notes,
      status:'airborne',lodgedBy:window._currentUser.name,
      lodgedAt:serverTimestamp(),lodgedTime:localNow()
    });
    await writeLog('dep',`<b>${rego}</b> departed ${dep} → ${dest} | Pilot: ${pilot} | SARTIME: ${sartime} | POB: ${pax}`);
    showToast('Flight lodged — live on all devices','success');
    clearCheckin(); showView('ops');
  }catch(e){showToast('Saved offline — syncs when signal returns','info');clearCheckin();showView('ops');}
  btn.disabled=false; btn.textContent='✈ Lodge Flight & SARTIME';
};

window.cancelSARTIME=async function(){
  const id=document.getElementById('cancel-flight').value;
  const t=document.getElementById('cancel-time').value||localNow();
  if(!id){showToast('Select a flight to cancel','error');return;}
  const f=(window._flights||[]).find(x=>x.id===id);
  if(!f) return;
  // Check permission
  if(window._currentUser.role==='pilot' && f.pilot!==window._currentUser.name){
    showToast('You can only cancel your own flights','error'); return;
  }
  try{
    await updateDoc(doc(db,'flights',id),{status:'landed',landedAt:t,cancelledBy:window._currentUser.name});
    await writeLog('arr',`<b>${f.rego}</b> SARTIME cancelled — ${f.pilot} landed at ${t} | ${f.dep}→${f.dest}`);
    showToast('SARTIME cancelled — OPS notified','success');
  }catch(e){showToast('Saved offline — syncs when signal returns','info');}
};

window.markLanded=async function(id){
  const f=(window._flights||[]).find(x=>x.id===id);
  if(!f) return;
  // Pilots can only mark their own flights
  if(window._currentUser.role==='pilot' && f.pilot!==window._currentUser.name){
    showToast('You can only mark your own flight as landed','error'); return;
  }
  try{
    await updateDoc(doc(db,'flights',id),{status:'landed',landedAt:localNow(),cancelledBy:window._currentUser.name});
    await writeLog('arr',`<b>${f.rego}</b> marked landed | Pilot: ${f.pilot}`);
    showToast('Flight marked landed','success');
  }catch(e){showToast('Update saved offline','info');}
};

window.removeFlight=async function(id){
  try{ await updateDoc(doc(db,'flights',id),{status:'archived'}); }catch(e){}
};

window.addPilot=async function(){
  const name=document.getElementById('new-pilot-name').value.trim();
  const phone=document.getElementById('new-pilot-phone').value.trim();
  const password=document.getElementById('new-pilot-password').value.trim();
  const ratings=document.getElementById('new-pilot-ratings').value.trim();
  if(!name||!password){showToast('Name and password required','error');return;}
  try{
    await addDoc(collection(db,'pilots'),{name,phone,password,ratings,addedAt:serverTimestamp()});
    await writeLog('admin',`Pilot added: ${name}`);
    ['new-pilot-name','new-pilot-phone','new-pilot-password','new-pilot-ratings'].forEach(id=>document.getElementById(id).value='');
    showToast('Pilot added','success');
  }catch(e){showToast('Error adding pilot','error');}
};

window.deletePilot=async function(id,name){
  if(!confirm(`Remove ${name}?`)) return;
  try{
    await deleteDoc(doc(db,'pilots',id));
    await writeLog('admin',`Pilot removed: ${name}`);
    showToast('Pilot removed','info');
  }catch(e){showToast('Error','error');}
};

window.updatePilotPassword=async function(id,name){
  const pw=prompt(`Set new password for ${name}:`);
  if(!pw) return;
  try{
    await updateDoc(doc(db,'pilots',id),{password:pw});
    await writeLog('admin',`Password updated for ${name}`);
    showToast('Password updated','success');
  }catch(e){showToast('Error','error');}
};

window.addAircraft=async function(){
  const rego=document.getElementById('new-ac-rego').value.toUpperCase().trim();
  const type=document.getElementById('new-ac-type').value;
  if(!rego){showToast('Enter a rego','error');return;}
  try{
    await addDoc(collection(db,'aircraft'),{rego,type,addedAt:serverTimestamp()});
    await writeLog('admin',`Aircraft added: ${rego} (${type})`);
    document.getElementById('new-ac-rego').value='';
    showToast('Aircraft added','success');
  }catch(e){showToast('Error','error');}
};

window.deleteAircraft=async function(id,rego){
  if(!confirm(`Remove ${rego}?`)) return;
  try{
    await deleteDoc(doc(db,'aircraft',id));
    await writeLog('admin',`Aircraft removed: ${rego}`);
    showToast('Aircraft removed','info');
  }catch(e){showToast('Error','error');}
};

window.saveOpsSettings=async function(){
  const opsName=document.getElementById('ops-name').value.trim();
  const opsPhone=document.getElementById('ops-phone').value.trim();
  const cpName=document.getElementById('cp-name').value.trim();
  const cpPhone=document.getElementById('cp-phone').value.trim();
  const opsPassword=document.getElementById('ops-password-set').value.trim();
  if(!opsPassword){showToast('Ops password cannot be blank','error');return;}
  try{
    await setDoc(doc(db,'settings','ops'),{opsName,opsPhone,cpName,cpPhone,opsPassword});
    await writeLog('admin',`Settings updated by ${window._currentUser?.name||'ops'}`);
    showToast('Settings saved — all devices updated','success');
  }catch(e){showToast('Error saving','error');}
};

setSyncStatus('connecting');
