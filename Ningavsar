<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="theme-color" content="#07090d">
<title>Ningaloo Aviation — FlightWatch SAR</title>
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Share+Tech+Mono&family=Exo+2:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#07090d;--bg2:#0b0f15;--panel:#0f1520;--panel2:#131c28;
  --border:#1a2535;--border2:#243040;
  --accent:#00c8ff;--accent2:#0077aa;
  --green:#00e676;--green2:#00a152;
  --amber:#ffab00;--red:#ff1744;
  --text:#cdd8e8;--text2:#7a9ab8;--text3:#3d5a73;
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
body{background:var(--bg);color:var(--text);font-family:'Exo 2',sans-serif;min-height:100vh;overflow-x:hidden;}
body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(var(--border) 1px,transparent 1px),linear-gradient(90deg,var(--border) 1px,transparent 1px);background-size:40px 40px;opacity:0.18;pointer-events:none;z-index:0;}

/* LOGIN SCREEN */
.login-screen{position:fixed;inset:0;z-index:500;background:var(–bg);display:flex;align-items:center;justify-content:center;padding:24px;}
.login-screen.hidden{display:none;}
.login-box{background:var(–panel);border:1px solid var(–border2);border-radius:10px;padding:36px 28px;width:min(400px,100%);position:relative;}
.login-logo{font-family:‘Rajdhani’,sans-serif;font-size:1.6rem;font-weight:700;color:var(–accent);letter-spacing:3px;text-transform:uppercase;text-align:center;margin-bottom:4px;}
.login-sub{font-size:0.78rem;color:var(–text2);text-align:center;letter-spacing:2px;text-transform:uppercase;margin-bottom:30px;}
.login-role-tabs{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:24px;}
.login-role-btn{padding:10px;border:1px solid var(–border2);background:transparent;color:var(–text2);font-family:‘Rajdhani’,sans-serif;font-size:0.88rem;font-weight:600;letter-spacing:1px;cursor:pointer;text-transform:uppercase;border-radius:4px;transition:all 0.2s;}
.login-role-btn.active{background:var(–accent2);border-color:var(–accent);color:#fff;}
.login-role-btn.ops-btn.active{background:rgba(255,171,0,0.2);border-color:var(–amber);color:var(–amber);}
.login-form-group{display:flex;flex-direction:column;gap:6px;margin-bottom:14px;}
.login-label{font-family:‘Rajdhani’,sans-serif;font-size:0.7rem;letter-spacing:2px;text-transform:uppercase;color:var(–text3);}
.login-input,.login-select{background:var(–bg2);border:1px solid var(–border2);color:var(–text);padding:12px 14px;border-radius:4px;font-family:‘Exo 2’,sans-serif;font-size:0.95rem;outline:none;width:100%;transition:border-color 0.2s;}
.login-input:focus,.login-select:focus{border-color:var(–accent);}
.login-select option{background:var(–bg2);}
.login-btn{width:100%;padding:13px;background:var(–accent2);border:1px solid var(–accent);color:#fff;font-family:‘Rajdhani’,sans-serif;font-size:1rem;font-weight:700;letter-spacing:2px;cursor:pointer;border-radius:4px;text-transform:uppercase;transition:all 0.2s;margin-top:6px;}
.login-btn:hover{background:var(–accent);}
.login-btn.ops-login-btn{background:rgba(255,171,0,0.2);border-color:var(–amber);color:var(–amber);}
.login-btn.ops-login-btn:hover{background:rgba(255,171,0,0.35);}
.login-error{color:var(–red);font-size:0.82rem;text-align:center;margin-top:10px;display:none;}
.login-error.show{display:block;}
.stay-logged-in{display:flex;align-items:center;gap:8px;margin-bottom:14px;font-size:0.82rem;color:var(–text2);}
.stay-logged-in input{accent-color:var(–accent);}

/* NAV USER BADGE */
.nav-user{display:flex;align-items:center;gap:8px;font-size:0.78rem;}
.user-badge{padding:4px 10px;border-radius:12px;font-family:‘Rajdhani’,sans-serif;font-size:0.72rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;}
.user-badge.pilot{background:rgba(0,200,255,0.15);border:1px solid var(–accent2);color:var(–accent);}
.user-badge.ops{background:rgba(255,171,0,0.15);border:1px solid rgba(255,171,0,0.4);color:var(–amber);}
.logout-btn{padding:4px 10px;border:1px solid var(–border2);background:transparent;color:var(–text3);font-family:‘Rajdhani’,sans-serif;font-size:0.7rem;font-weight:600;letter-spacing:1px;cursor:pointer;text-transform:uppercase;border-radius:3px;transition:all 0.2s;}
.logout-btn:hover{border-color:var(–red);color:var(–red);}

/* SYNC BAR */
.sync-bar{position:fixed;top:0;left:0;right:0;z-index:200;height:3px;background:var(–bg2);}
.sync-bar-fill{height:100%;width:0;background:var(–accent);transition:width 0.3s;}
.sync-indicator{position:fixed;bottom:70px;right:16px;z-index:200;display:flex;align-items:center;gap:6px;background:rgba(15,21,32,0.95);border:1px solid var(–border2);border-radius:20px;padding:5px 12px;font-size:0.72rem;font-family:‘Rajdhani’,sans-serif;letter-spacing:1px;text-transform:uppercase;}
.sync-dot{width:7px;height:7px;border-radius:50%;}
.sync-dot.live{background:var(–green);box-shadow:0 0 6px var(–green);animation:blink 2s infinite;}
.sync-dot.offline{background:var(–amber);box-shadow:0 0 6px var(–amber);}
.sync-dot.error{background:var(–red);}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0.4}}

/* NAV */
nav{position:sticky;top:0;z-index:100;background:rgba(7,9,13,0.97);border-bottom:1px solid var(–border2);backdrop-filter:blur(12px);display:flex;align-items:center;justify-content:space-between;padding:0 16px;height:56px;gap:10px;}
.nav-brand{font-family:‘Rajdhani’,sans-serif;font-size:1.1rem;font-weight:700;letter-spacing:2px;color:var(–accent);text-transform:uppercase;display:flex;align-items:center;gap:6px;flex-shrink:0;}
.nav-brand span{color:var(–text2);font-weight:400;font-size:0.65rem;letter-spacing:1px;display:block;line-height:1.1;}
.nav-clock{font-family:‘Share Tech Mono’,monospace;font-size:0.85rem;color:var(–accent);letter-spacing:2px;flex-shrink:0;}
.nav-tabs{display:flex;gap:3px;}
.nav-tab{padding:5px 12px;border:1px solid var(–border2);background:transparent;color:var(–text2);font-family:‘Rajdhani’,sans-serif;font-size:0.8rem;font-weight:600;letter-spacing:1px;cursor:pointer;text-transform:uppercase;transition:all 0.2s;border-radius:3px;}
.nav-tab:hover{border-color:var(–accent);color:var(–accent);}
.nav-tab.active{background:var(–accent2);border-color:var(–accent);color:#fff;}
.nav-tab.admin-tab{border-color:rgba(255,171,0,0.3);color:var(–amber);}
.nav-tab.admin-tab.active{background:rgba(255,171,0,0.2);border-color:var(–amber);}
.nav-tab.hidden-tab{display:none;}

/* VIEWS */
.view{display:none;position:relative;z-index:1;padding:18px;max-width:1400px;margin:0 auto;}
.view.active{display:block;}

/* SECTION HEADER */
.section-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;}
.section-title{font-family:‘Rajdhani’,sans-serif;font-size:1.05rem;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(–accent);display:flex;align-items:center;gap:8px;}
.section-title::before{content:’’;width:3px;height:15px;background:var(–accent);border-radius:2px;}
.section-title.amber-title{color:var(–amber);}
.section-title.amber-title::before{background:var(–amber);}

/* STATS */
.stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:18px;}
.stat-card{background:var(–panel);border:1px solid var(–border2);border-radius:6px;padding:12px 14px;display:flex;flex-direction:column;gap:3px;position:relative;overflow:hidden;}
.stat-card::after{content:’’;position:absolute;top:0;left:0;width:100%;height:2px;}
.stat-card.blue::after{background:var(–accent);}
.stat-card.green::after{background:var(–green);}
.stat-card.amber::after{background:var(–amber);}
.stat-card.red::after{background:var(–red);}
.stat-label{font-size:0.62rem;letter-spacing:2px;text-transform:uppercase;color:var(–text3);}
.stat-value{font-family:‘Rajdhani’,sans-serif;font-size:1.8rem;font-weight:700;line-height:1;}
.stat-card.blue .stat-value{color:var(–accent);}
.stat-card.green .stat-value{color:var(–green);}
.stat-card.amber .stat-value{color:var(–amber);}
.stat-card.red .stat-value{color:var(–red);}

/* ALERT BANNER */
.alert-banner{display:none;background:rgba(255,23,68,0.09);border:1px solid rgba(255,23,68,0.5);border-radius:6px;padding:12px 16px;margin-bottom:16px;animation:alertPulse 2s infinite;align-items:center;gap:12px;flex-wrap:wrap;}
.alert-banner.show{display:flex;}
@keyframes alertPulse{0%,100%{border-color:rgba(255,23,68,0.5);}50%{border-color:rgba(255,23,68,1);box-shadow:0 0 20px rgba(255,23,68,0.15);}}
.alert-icon{font-size:1.3rem;}
.alert-text{flex:1;min-width:180px;}
.alert-title{font-family:‘Rajdhani’,sans-serif;font-weight:700;font-size:0.92rem;color:var(–red);letter-spacing:1px;text-transform:uppercase;}
.alert-detail{font-size:0.78rem;color:var(–text2);margin-top:2px;}
.alert-actions{display:flex;gap:7px;flex-wrap:wrap;}
.btn-alert-sms{padding:6px 11px;background:rgba(255,171,0,0.15);border:1px solid var(–amber);color:var(–amber);font-family:‘Rajdhani’,sans-serif;font-size:0.72rem;font-weight:700;letter-spacing:1px;cursor:pointer;border-radius:3px;text-transform:uppercase;}
.btn-alert-checklist{padding:6px 11px;background:rgba(255,23,68,0.15);border:1px solid var(–red);color:var(–red);font-family:‘Rajdhani’,sans-serif;font-size:0.72rem;font-weight:700;letter-spacing:1px;cursor:pointer;border-radius:3px;text-transform:uppercase;}

/* TABLE */
.flight-table-wrap{background:var(–panel);border:1px solid var(–border2);border-radius:6px;overflow:auto;}
.flight-table{width:100%;border-collapse:collapse;min-width:700px;}
.flight-table th{background:var(–panel2);padding:9px 12px;font-family:‘Rajdhani’,sans-serif;font-size:0.68rem;letter-spacing:2px;text-transform:uppercase;color:var(–text3);text-align:left;border-bottom:1px solid var(–border2);white-space:nowrap;}
.flight-table td{padding:10px 12px;border-bottom:1px solid var(–border);font-size:0.84rem;vertical-align:middle;}
.flight-table tr:last-child td{border-bottom:none;}
.flight-table tr:hover td{background:rgba(0,200,255,0.03);}
.flight-table tr.overdue td{background:rgba(255,23,68,0.07);}
.flight-table tr.warning td{background:rgba(255,171,0,0.04);}
.rego{font-family:‘Share Tech Mono’,monospace;color:var(–accent);font-size:0.84rem;}
.time-mono{font-family:‘Share Tech Mono’,monospace;font-size:0.8rem;}
.sar-countdown{font-family:‘Share Tech Mono’,monospace;font-size:0.84rem;font-weight:bold;}
.sar-countdown.ok{color:var(–green);}
.sar-countdown.warn{color:var(–amber);}
.sar-countdown.overdue{color:var(–red);animation:pulse 1s infinite;}
.sar-countdown.pending{color:var(–text3);}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.35}}
.badge{display:inline-block;padding:3px 8px;border-radius:3px;font-family:‘Rajdhani’,sans-serif;font-size:0.68rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;white-space:nowrap;}
.badge-airborne{background:rgba(0,230,118,0.15);color:var(–green);border:1px solid rgba(0,230,118,0.3);}
.badge-landed{background:rgba(61,90,115,0.3);color:var(–text3);border:1px solid var(–border);}
.badge-overdue{background:rgba(255,23,68,0.2);color:var(–red);border:1px solid rgba(255,23,68,0.4);animation:pulse 1s infinite;}
.badge-warning{background:rgba(255,171,0,0.15);color:var(–amber);border:1px solid rgba(255,171,0,0.3);}
.badge-own{background:rgba(0,200,255,0.1);color:var(–accent);border:1px solid var(–accent2);font-size:0.6rem;padding:2px 6px;margin-left:4px;}

/* BUTTONS */
.btn{padding:5px 11px;border-radius:3px;border:1px solid;font-family:‘Rajdhani’,sans-serif;font-size:0.74rem;font-weight:600;letter-spacing:1px;cursor:pointer;text-transform:uppercase;transition:all 0.15s;}
.btn-land{border-color:var(–green2);color:var(–green);background:rgba(0,230,118,0.08);}
.btn-land:hover{background:rgba(0,230,118,0.2);}
.btn-land:disabled{opacity:0.3;cursor:not-allowed;}
.btn-remove{border-color:var(–border2);color:var(–text3);background:transparent;}
.btn-remove:hover{border-color:var(–red);color:var(–red);}
.btn-primary{padding:10px 20px;background:var(–accent2);border:1px solid var(–accent);color:#fff;font-family:‘Rajdhani’,sans-serif;font-size:0.9rem;font-weight:700;letter-spacing:2px;cursor:pointer;border-radius:4px;text-transform:uppercase;transition:all 0.2s;}
.btn-primary:hover{background:var(–accent);box-shadow:0 0 16px rgba(0,200,255,0.3);}
.btn-primary:disabled{opacity:0.5;cursor:not-allowed;}
.btn-secondary{padding:10px 20px;background:transparent;border:1px solid var(–border2);color:var(–text2);font-family:‘Rajdhani’,sans-serif;font-size:0.9rem;font-weight:600;letter-spacing:2px;cursor:pointer;border-radius:4px;text-transform:uppercase;transition:all 0.2s;}
.btn-secondary:hover{border-color:var(–accent);color:var(–accent);}
.btn-amber{padding:10px 20px;background:rgba(255,171,0,0.15);border:1px solid var(–amber);color:var(–amber);font-family:‘Rajdhani’,sans-serif;font-size:0.9rem;font-weight:700;letter-spacing:2px;cursor:pointer;border-radius:4px;text-transform:uppercase;transition:all 0.2s;}
.btn-amber:hover{background:rgba(255,171,0,0.28);}
.btn-danger{padding:6px 11px;background:rgba(255,23,68,0.1);border:1px solid rgba(255,23,68,0.3);color:var(–red);font-family:‘Rajdhani’,sans-serif;font-size:0.74rem;font-weight:600;letter-spacing:1px;cursor:pointer;border-radius:3px;text-transform:uppercase;transition:all 0.15s;}
.btn-danger:hover{background:rgba(255,23,68,0.25);}

/* FORM */
.form-panel{background:var(–panel);border:1px solid var(–border2);border-radius:6px;padding:22px;}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:13px;}
.form-group{display:flex;flex-direction:column;gap:5px;}
.form-group.full{grid-column:1/-1;}
.form-label{font-family:‘Rajdhani’,sans-serif;font-size:0.68rem;letter-spacing:2px;text-transform:uppercase;color:var(–text3);}
.form-input,.form-select{background:var(–bg2);border:1px solid var(–border2);color:var(–text);padding:10px 12px;border-radius:4px;font-family:‘Exo 2’,sans-serif;font-size:0.88rem;transition:border-color 0.2s;outline:none;width:100%;}
.form-input:focus,.form-select:focus{border-color:var(–accent);}
.form-select option{background:var(–bg2);}
.form-actions{display:flex;gap:10px;justify-content:flex-end;margin-top:14px;flex-wrap:wrap;}
.form-hint{font-size:0.72rem;color:var(–text3);margin-top:2px;}

/* ADMIN */
.admin-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-bottom:20px;}
.admin-section{background:var(–panel);border:1px solid var(–border2);border-radius:6px;padding:18px;}
.admin-section-title{font-family:‘Rajdhani’,sans-serif;font-size:0.82rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(–amber);margin-bottom:12px;}
.admin-list{display:flex;flex-direction:column;gap:7px;margin-bottom:14px;max-height:260px;overflow-y:auto;}
.admin-item{display:flex;align-items:center;justify-content:space-between;background:var(–bg2);border:1px solid var(–border);border-radius:4px;padding:8px 11px;gap:10px;}
.admin-item-info{flex:1;}
.admin-item-name{font-weight:600;font-size:0.86rem;}
.admin-item-sub{font-size:0.72rem;color:var(–text2);font-family:‘Share Tech Mono’,monospace;margin-top:2px;}
.admin-item-actions{display:flex;gap:6px;align-items:center;}
.admin-add-row{display:flex;gap:7px;align-items:flex-end;flex-wrap:wrap;}
.admin-add-row .form-input{flex:1;min-width:100px;padding:8px 10px;}
.admin-add-row .form-select{flex:1;min-width:90px;padding:8px 10px;}
.admin-empty{text-align:center;padding:18px;color:var(–text3);font-family:‘Rajdhani’,sans-serif;font-size:0.78rem;letter-spacing:1px;}
.password-hint{font-size:0.72rem;color:var(–text3);margin-top:4px;}

/* CONTACTS */
.contacts-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(210px,1fr));gap:11px;}
.contact-card{background:var(–panel);border:1px solid var(–border2);border-radius:6px;padding:13px;position:relative;overflow:hidden;}
.contact-card::before{content:’’;position:absolute;top:0;left:0;width:3px;height:100%;}
.contact-card.pilot::before{background:var(–accent);}
.contact-card.ops::before{background:var(–amber);}
.contact-card.emergency::before{background:var(–red);}
.contact-role{font-family:‘Rajdhani’,sans-serif;font-size:0.64rem;letter-spacing:2px;text-transform:uppercase;color:var(–text3);margin-bottom:3px;}
.contact-name{font-weight:600;font-size:0.92rem;margin-bottom:4px;}
.contact-detail{font-family:‘Share Tech Mono’,monospace;font-size:0.76rem;color:var(–accent);margin-bottom:2px;}
.contact-sub{font-size:0.72rem;color:var(–text2);}

/* AIRCRAFT FLEET */
.aircraft-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:10px;}
.aircraft-card{background:var(–panel);border:1px solid var(–border2);border-radius:6px;padding:12px;text-align:center;transition:border-color 0.3s;}
.aircraft-card.available{border-color:var(–green2);}
.aircraft-card.airborne{border-color:var(–accent2);}
.aircraft-card.overdue-ac{border-color:var(–red);animation:pulse 2s infinite;}
.aircraft-rego{font-family:‘Rajdhani’,sans-serif;font-size:1.15rem;font-weight:700;color:var(–accent);}
.aircraft-type{font-size:0.68rem;color:var(–text3);margin-bottom:6px;}
.status-dot{width:7px;height:7px;border-radius:50%;display:inline-block;margin-right:4px;}
.dot-green{background:var(–green);box-shadow:0 0 5px var(–green);}
.dot-blue{background:var(–accent);box-shadow:0 0 5px var(–accent);}
.dot-red{background:var(–red);box-shadow:0 0 5px var(–red);animation:pulse 1s infinite;}
.dot-grey{background:var(–text3);}

/* MODALS */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.88);z-index:1000;align-items:center;justify-content:center;padding:16px;}
.modal-overlay.show{display:flex;}
.modal{background:var(–panel);border:1px solid var(–border2);border-radius:8px;padding:24px;width:min(560px,100%);max-height:88vh;overflow-y:auto;animation:slideUp 0.25s ease;}
@keyframes slideUp{from{transform:translateY(14px);opacity:0}to{transform:translateY(0);opacity:1}}
.modal-title{font-family:‘Rajdhani’,sans-serif;font-size:1.2rem;font-weight:700;color:var(–red);letter-spacing:2px;text-transform:uppercase;margin-bottom:4px;}
.modal-subtitle{font-size:0.8rem;color:var(–text2);margin-bottom:18px;line-height:1.5;background:rgba(255,23,68,0.05);border:1px solid rgba(255,23,68,0.15);border-radius:4px;padding:8px 11px;}
.checklist-step{display:flex;gap:11px;align-items:flex-start;padding:11px 0;border-bottom:1px solid var(–border);}
.checklist-step:last-child{border-bottom:none;}
.step-num{width:25px;height:25px;border-radius:50%;background:var(–panel2);border:1px solid var(–border2);display:flex;align-items:center;justify-content:center;font-family:‘Share Tech Mono’,monospace;font-size:0.74rem;color:var(–text3);flex-shrink:0;margin-top:2px;cursor:pointer;transition:all 0.2s;user-select:none;}
.step-num.done{background:var(–green2);border-color:var(–green);color:#fff;}
.step-body{flex:1;}
.step-title{font-weight:600;font-size:0.89rem;margin-bottom:3px;}
.step-detail{font-size:0.76rem;color:var(–text2);line-height:1.55;}
.step-time{font-family:‘Share Tech Mono’,monospace;font-size:0.68rem;color:var(–amber);margin-top:3px;}
.modal-close-btn{width:100%;margin-top:14px;padding:10px;background:transparent;border:1px solid var(–border2);color:var(–text2);font-family:‘Rajdhani’,sans-serif;font-size:0.88rem;font-weight:600;letter-spacing:2px;cursor:pointer;border-radius:4px;text-transform:uppercase;transition:all 0.2s;}
.modal-close-btn:hover{border-color:var(–accent);color:var(–accent);}

/* SMS MODAL */
.sms-modal{background:var(–panel);border:1px solid var(–amber);border-radius:8px;padding:22px;width:min(420px,100%);animation:slideUp 0.25s ease;}
.sms-title{font-family:‘Rajdhani’,sans-serif;font-size:1.05rem;font-weight:700;color:var(–amber);letter-spacing:2px;text-transform:uppercase;margin-bottom:11px;}
.sms-preview{background:var(–bg2);border:1px solid var(–border2);border-radius:4px;padding:11px;font-family:‘Share Tech Mono’,monospace;font-size:0.76rem;color:var(–text);line-height:1.75;margin-bottom:14px;white-space:pre-wrap;}
.sms-recipient{display:flex;align-items:center;gap:9px;padding:7px 0;border-bottom:1px solid var(–border);}
.sms-recipient:last-child{border-bottom:none;}
.sms-check{width:15px;height:15px;accent-color:var(–amber);}
.sms-name{font-weight:600;font-size:0.84rem;}
.sms-num{font-family:‘Share Tech Mono’,monospace;font-size:0.74rem;color:var(–text2);}
.btn-send-sms{width:100%;padding:10px;margin-top:12px;background:rgba(255,171,0,0.15);border:1px solid var(–amber);color:var(–amber);font-family:‘Rajdhani’,sans-serif;font-size:0.9rem;font-weight:700;letter-spacing:2px;cursor:pointer;border-radius:4px;text-transform:uppercase;transition:all 0.2s;}
.btn-send-sms:hover{background:rgba(255,171,0,0.28);}
.sent-confirm{display:none;text-align:center;color:var(–green);font-family:‘Rajdhani’,sans-serif;font-size:0.9rem;letter-spacing:1px;padding:7px;}

/* LOG */
.log-entry{display:flex;gap:9px;padding:8px 0;border-bottom:1px solid var(–border);font-size:0.8rem;align-items:flex-start;}
.log-time{font-family:‘Share Tech Mono’,monospace;color:var(–text3);white-space:nowrap;font-size:0.73rem;margin-top:1px;}
.log-msg{color:var(–text);flex:1;line-height:1.5;}
.log-msg b{color:var(–accent);}
.log-type{padding:2px 6px;border-radius:2px;font-family:‘Rajdhani’,sans-serif;font-size:0.63rem;font-weight:700;letter-spacing:1px;white-space:nowrap;}
.log-type.dep{background:rgba(0,200,255,0.1);color:var(–accent);}
.log-type.arr{background:rgba(0,230,118,0.1);color:var(–green);}
.log-type.sar{background:rgba(255,23,68,0.1);color:var(–red);}
.log-type.info{background:rgba(61,90,115,0.2);color:var(–text3);}
.log-type.admin{background:rgba(255,171,0,0.1);color:var(–amber);}

.divider{border:none;border-top:1px solid var(–border);margin:18px 0;}
.offline-notice{display:none;background:rgba(255,171,0,0.08);border:1px solid rgba(255,171,0,0.3);border-radius:5px;padding:9px 13px;margin-bottom:14px;font-size:0.8rem;color:var(–amber);}
.offline-notice.show{display:block;}

/* TOAST */
.toast{position:fixed;bottom:80px;left:50%;transform:translateX(-50%) translateY(20px);background:var(–panel2);border:1px solid var(–border2);border-radius:6px;padding:10px 20px;font-family:‘Rajdhani’,sans-serif;font-size:0.86rem;letter-spacing:1px;z-index:500;opacity:0;transition:all 0.3s;white-space:nowrap;pointer-events:none;}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0);}
.toast.success{border-color:var(–green);color:var(–green);}
.toast.error{border-color:var(–red);color:var(–red);}
.toast.info{border-color:var(–accent);color:var(–accent);}

