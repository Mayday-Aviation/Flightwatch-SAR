<script>
// ── STATE
window._flights=[];
window._pilots=[];
window._aircraft=[];
window._opsSettings={};
window._currentUser=null;
let overdueFlights=[];

// ── CLOCK
function updateClock(){const n=new Date(),p=v=>String(v).padStart(2,'0');document.getElementById('clock').textContent=p(n.getUTCHours())+':'+p(n.getUTCMinutes())+':'+p(n.getUTCSeconds())+' UTC';}
setInterval(updateClock,1000);updateClock();

function timeToMins(t){if(!t)return null;const[h,m]=t.split(':').map(Number);return h*60+m;}
function nowMins(){const n=new Date();return n.getHours()*60+n.getMinutes();}
function minsToHHMM(m){return String(Math.floor(Math.abs(m)/60)).padStart(2,'0')+':'+String(Math.abs(m)%60).padStart(2,'0');}
function localNow(){const n=new Date();return String(n.getHours()).padStart(2,'0')+':'+String(n.getMinutes()).padStart(2,'0');}

// ── LOGIN
function setLoginRole(role){
  document.getElementById('pilot-login-form').style.display=role==='pilot'?'block':'none';
  document.getElementById('ops-login-form').style.display=role==='ops'?'block':'none';
  document.getElementById('role-pilot-btn').classList.toggle('active',role==='pilot');
  document.getElementById('role-ops-btn').classList.toggle('active',role==='ops');
  document.getElementById('login-error').classList.remove('show');
}

function populateLoginDropdown(){
  const sel=document.getElementById('login-pilot-name');
  const val=sel.value;
  sel.innerHTML='<option value="">— Select your name —</option>';
  (window._pilots||[]).forEach(p=>{
    const o=document.createElement('option');o.value=p.name;o.textContent=p.name;sel.appendChild(o);
  });
  if(val) sel.value=val;
}

function loginPilot(){
  const name=document.getElementById('login-pilot-name').value;
  const password=document.getElementById('login-pilot-password').value;
  const stay=document.getElementById('stay-logged-in').checked;
  if(!name||!password){showLoginError();return;}
  const pilot=(window._pilots||[]).find(p=>p.name===name && p.password===password);
  if(!pilot){showLoginError();return;}
  setCurrentUser({role:'pilot',name:pilot.name,phone:pilot.phone},stay);
}

function loginOps(){
  const password=document.getElementById('login-ops-password').value;
  const stay=document.getElementById('stay-logged-in-ops').checked;
  const correctPw=(window._opsSettings||{}).opsPassword;
  if(!correctPw){showToast('No ops password set yet — go to Admin to set one','error');return;}
  if(password!==correctPw){showLoginError();return;}
  setCurrentUser({role:'ops',name:(window._opsSettings.opsName||'Operations')},stay);
}

function showLoginError(){
  document.getElementById('login-error').classList.add('show');
  setTimeout(()=>document.getElementById('login-error').classList.remove('show'),3000);
}

function setCurrentUser(user, persist){
  window._currentUser=user;
  if(persist) localStorage.setItem('fw_user',JSON.stringify(user));
  showMainApp();
}

function showMainApp(){
  const user=window._currentUser;
  document.getElementById('login-screen').classList.add('hidden');
  document.getElementById('main-app').style.display='block';
  // User badge
  const badge=document.getElementById('user-badge');
  badge.textContent=user.role==='ops'?'⚙ Operations':'✈ '+user.name;
  badge.className='user-badge '+(user.role==='ops'?'ops':'pilot');
  // Show/hide admin
  const isOps=user.role==='ops';
  document.getElementById('admin-nav-tab').classList.toggle('hidden-tab',!isOps);
  document.getElementById('admin-mob-tab').classList.toggle('hidden-tab',!isOps);
  // Pre-fill pilot name in check-in if pilot
  if(user.role==='pilot'){
    setTimeout(()=>{
      const sel=document.getElementById('ci-pilot');
      if(sel) sel.value=user.name;
      // Pre-fill phone
      const pilot=(window._pilots||[]).find(p=>p.name===user.name);
      if(pilot && document.getElementById('ci-phone')) document.getElementById('ci-phone').value=pilot.phone||'';
    },500);
  }
}

function logout(){
  window._currentUser=null;
  localStorage.removeItem('fw_user');
  document.getElementById('login-screen').classList.remove('hidden');
  document.getElementById('main-app').style.display='none';
  document.getElementById('login-pilot-password').value='';
  document.getElementById('login-ops-password').value='';
}

// ── CHECK PERSISTED LOGIN
function checkPersistedLogin(){
  try{
    const saved=localStorage.getItem('fw_user');
    if(saved){
      const user=JSON.parse(saved);
      window._currentUser=user;
      showMainApp();
    }
  }catch(e){}
}
checkPersistedLogin();

// ── SYNC STATUS
function setSyncStatus(state){
  const dot=document.getElementById('sync-dot'),label=document.getElementById('sync-label'),bar=document.getElementById('sync-bar-fill');
  const notices=document.querySelectorAll('.offline-notice');
  dot.className='sync-dot';
  if(state==='live'){dot.classList.add('live');label.textContent='Live';bar.style.background='var(--green)';bar.style.width='100%';notices.forEach(n=>n.classList.remove('show'));setTimeout(()=>bar.style.width='0',1500);}
  else if(state==='offline'){dot.classList.add('offline');label.textContent='Offline — queued';bar.style.background='var(--amber)';bar.style.width='100%';notices.forEach(n=>n.classList.add('show'));}
  else if(state==='error'){dot.classList.add('error');}
  else{dot.classList.add('offline');label.textContent='Connecting...';}
}

// ── VIEWS
function showView(name){
  document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));
  document.querySelectorAll('.nav-tab,.mobile-nav-btn').forEach(t=>t.classList.remove('active'));
  document.getElementById('view-'+name).classList.add('active');
  const order=['ops','pilot','aircraft','contacts','log','admin'];
  const i=order.indexOf(name);
  document.querySelectorAll('.nav-tab')[i]?.classList.add('active');
  document.querySelectorAll('.mobile-nav-btn')[i]?.classList.add('active');
  if(name==='aircraft') renderAircraft();
}

// ── DROPDOWNS
function populatePilotDropdown(){
  const sel=document.getElementById('ci-pilot');
  const val=sel.value;
  sel.innerHTML='<option value="">— Select Pilot —</option>';
  (window._pilots||[]).forEach(p=>{const o=document.createElement('option');o.value=p.name;o.textContent=p.name;sel.appendChild(o);});
  if(val) sel.value=val;
  // If pilot logged in, lock to their name
  if(window._currentUser?.role==='pilot'){
    sel.value=window._currentUser.name;
    sel.disabled=true;
  } else { sel.disabled=false; }
}

function populateAircraftDropdown(){
  const sel=document.getElementById('ci-rego');
  const val=sel.value;
  sel.innerHTML='<option value="">— Select Aircraft —</option>';
  (window._aircraft||[]).forEach(a=>{const o=document.createElement('option');o.value=`${a.rego} — ${a.type}`;o.textContent=`${a.rego} — ${a.type}`;sel.appendChild(o);});
  if(val) sel.value=val;
}

// ── TABLE
function renderTable(){
  const tbody=document.getElementById('flights-tbody');
  const now=nowMins();
  overdueFlights=[];
  let airborne=0,warnings=0,overdue=0;
  const active=(window._flights||[]).filter(f=>f.status==='airborne'||f.status==='landed');
  if(!active.length){
    tbody.innerHTML='<tr><td colspan="9" style="text-align:center;color:var(--text3);padding:36px;font-family:Rajdhani,sans-serif;letter-spacing:2px;font-size:0.86rem;">NO ACTIVE FLIGHTS — ALL AIRCRAFT ON GROUND</td></tr>';
    ['stat-total','stat-airborne','stat-warning','stat-overdue'].forEach((id,i)=>document.getElementById(id).textContent=i===0?(window._flights||[]).filter(f=>f.status!=='archived').length:0);
    document.getElementById('overdue-banner').classList.remove('show');
    return;
  }
  tbody.innerHTML='';
  const cu=window._currentUser;
  active.forEach(f=>{
    if(f.status==='archived') return;
    const diff=timeToMins(f.sartime)-now;
    let countdown='',cClass='pending',rowClass='',statusBadge='',actionBtn='';
    const isOwn=cu&&(cu.role==='ops'||f.pilot===cu.name);
    const ownTag=isOwn&&cu.role==='pilot'?'<span class="badge badge-own">MINE</span>':'';
    if(f.status==='landed'){
      countdown='CANCELLED';cClass='pending';
      statusBadge=`<span class="badge badge-landed">Landed ${f.landedAt||''}</span>`;
      actionBtn=cu?.role==='ops'?`<button class="btn btn-remove" onclick="removeFlight('${f.id}')">Archive</button>`:'';
    } else {
      airborne++;
      // Land button — ops can land anyone, pilots only their own
      const canLand=cu&&(cu.role==='ops'||f.pilot===cu.name);
      actionBtn=canLand?`<button class="btn btn-land" onclick="markLanded('${f.id}')">✓ Landed</button>`:`<span style="font-size:0.72rem;color:var(--text3)">OPS only</span>`;
      if(diff<0){countdown='OVERDUE '+minsToHHMM(diff);cClass='overdue';rowClass='overdue';statusBadge='<span class="badge badge-overdue">OVERDUE</span>';overdue++;overdueFlights.push(f);}
      else if(diff<=30){countdown=minsToHHMM(diff)+' ⚠';cClass='warn';rowClass='warning';statusBadge='<span class="badge badge-warning">Warning</span>';warnings++;}
      else{countdown=minsToHHMM(diff);cClass='ok';statusBadge='<span class="badge badge-airborne">Airborne</span>';}
    }
    const tr=document.createElement('tr');tr.className=rowClass;
    tr.innerHTML=`<td><span class="rego">${f.rego}</span><br><span style="font-size:0.66rem;color:var(--text3)">${f.aircraft||''}</span></td><td><span style="font-weight:600">${f.pilot}</span>${ownTag}<br><span style="font-family:'Share Tech Mono',monospace;font-size:0.72rem;color:var(--text2)">${f.phone||'—'}</span></td><td><span style="color:var(--text2);font-size:0.82rem">${f.dep}<span style="color:var(--text3);margin:0 3px">→</span>${f.dest}</span></td><td><span class="time-mono">${f.etd}</span></td><td><span class="time-mono">${f.eta}</span></td><td><span class="time-mono" style="color:var(--amber)">${f.sartime}</span></td><td><span class="sar-countdown ${cClass}">${countdown}</span></td><td>${statusBadge}</td><td>${actionBtn}</td>`;
    tbody.appendChild(tr);
  });
  document.getElementById('stat-total').textContent=(window._flights||[]).filter(f=>f.status!=='archived').length;
  document.getElementById('stat-airborne').textContent=airborne;
  document.getElementById('stat-warning').textContent=warnings;
  document.getElementById('stat-overdue').textContent=overdue;
  document.getElementById('last-update').textContent='Updated '+localNow();
  if(overdueFlights.length){
    const f=overdueFlights[0];
    document.getElementById('banner-title').textContent=`🚨 SARTIME OVERDUE — ${f.rego} — ${f.pilot}`;
    document.getElementById('banner-detail').textContent=`Route: ${f.dep}→${f.dest} | SARTIME: ${f.sartime} | POB: ${f.pax} | Phone: ${f.phone}`;
    document.getElementById('overdue-banner').classList.add('show');
  } else {document.getElementById('overdue-banner').classList.remove('show');}
}

function updateCancelDropdown(){
  const sel=document.getElementById('cancel-flight');
  sel.innerHTML='<option value="">— Select flight —</option>';
  const cu=window._currentUser;
  (window._flights||[]).filter(f=>f.status==='airborne').forEach(f=>{
    // Pilots only see their own flights in cancel dropdown
    if(cu?.role==='pilot' && f.pilot!==cu.name) return;
    const o=document.createElement('option');o.value=f.id;o.textContent=`${f.rego} — ${f.pilot} — ${f.dep}→${f.dest}`;sel.appendChild(o);
  });
}

function renderAircraft(){
  const grid=document.getElementById('aircraft-grid');grid.innerHTML='';
  if(!window._aircraft.length){grid.innerHTML='<div style="color:var(--text3);font-family:Rajdhani,sans-serif;letter-spacing:2px;font-size:0.84rem;padding:18px;">No aircraft — add via Admin</div>';return;}
  window._aircraft.forEach(a=>{
    const f=(window._flights||[]).find(x=>x.rego===a.rego&&x.status==='airborne');
    let cls='available',dotCls='dot-green',statusTxt='Available';
    if(f){const d=timeToMins(f.sartime)-nowMins();if(d<0){cls='overdue-ac';dotCls='dot-red';statusTxt='OVERDUE';}else{cls='airborne';dotCls='dot-blue';statusTxt='Airborne';}}
    const card=document.createElement('div');card.className=`aircraft-card ${cls}`;
    card.innerHTML=`<div class="aircraft-rego">${a.rego}</div><div class="aircraft-type">${a.type}</div><div style="font-size:0.76rem"><span class="status-dot ${dotCls}"></span>${statusTxt}</div>${f?`<div style="font-size:0.69rem;color:var(--text2);margin-top:4px">${f.pilot}<br>${f.dep}→${f.dest}</div>`:''}`;
    grid.appendChild(card);
  });
}

function renderPilotList(){
  const el=document.getElementById('pilot-list');
  if(!window._pilots.length){el.innerHTML='<div class="admin-empty">No pilots added yet</div>';return;}
  el.innerHTML='';
  window._pilots.forEach(p=>{
    const div=document.createElement('div');div.className='admin-item';
    div.innerHTML=`<div class="admin-item-info"><div class="admin-item-name">${p.name}</div><div class="admin-item-sub">${p.phone||'No phone'} ${p.ratings?'· '+p.ratings:''}</div></div><div class="admin-item-actions"><button class="btn" style="border-color:var(--accent2);color:var(--accent);background:transparent;font-size:0.68rem;" onclick="updatePilotPassword('${p.id}','${p.name}')">🔑 PW</button><button class="btn-danger" onclick="deletePilot('${p.id}','${p.name}')">Remove</button></div>`;
    el.appendChild(div);
  });
}

function renderAircraftList(){
  const el=document.getElementById('aircraft-list');
  if(!window._aircraft.length){el.innerHTML='<div class="admin-empty">No aircraft added yet</div>';return;}
  el.innerHTML='';
  window._aircraft.forEach(a=>{
    const div=document.createElement('div');div.className='admin-item';
    div.innerHTML=`<div class="admin-item-info"><div class="admin-item-name" style="font-family:'Share Tech Mono',monospace;color:var(--accent)">${a.rego}</div><div class="admin-item-sub">${a.type}</div></div><button class="btn-danger" onclick="deleteAircraft('${a.id}','${a.rego}')">Remove</button>`;
    el.appendChild(div);
  });
}

function renderPilotContacts(){
  // Remove existing pilot cards
  document.querySelectorAll('#contacts-grid .contact-card.pilot').forEach(c=>c.remove());
  const grid=document.getElementById('contacts-grid');
  const emergencyCard=grid.querySelector('.contact-card.emergency');
  (window._pilots||[]).forEach(p=>{
    const card=document.createElement('div');card.className='contact-card pilot';
    card.innerHTML=`<div class="contact-role">Pilot</div><div class="contact-name">${p.name}</div><div class="contact-detail">📞 ${p.phone||'—'}</div><div class="contact-sub">${p.ratings||''}</div>`;
    grid.insertBefore(card,emergencyCard);
  });
}

function clearCheckin(){
  ['ci-phone','ci-dep','ci-dest','ci-etd','ci-eta','ci-sartime','ci-pax','ci-notes'].forEach(id=>{document.getElementById(id).value='';});
  document.getElementById('ci-rego').selectedIndex=0;
  document.getElementById('ci-type').selectedIndex=0;
  if(window._currentUser?.role==='pilot'){
    document.getElementById('ci-pilot').value=window._currentUser.name;
    const pilot=(window._pilots||[]).find(p=>p.name===window._currentUser.name);
    if(pilot) document.getElementById('ci-phone').value=pilot.phone||'';
  } else { document.getElementById('ci-pilot').selectedIndex=0; }
}

function openEscalationModal(){
  if(overdueFlights.length){const f=overdueFlights[0];document.getElementById('esc-subtitle').textContent=`Aircraft: ${f.rego} | Pilot: ${f.pilot} | ${f.dep}→${f.dest} | SARTIME: ${f.sartime} | POB: ${f.pax}`;}
  document.getElementById('escalation-modal').classList.add('show');
  if(window._writeLog) window._writeLog('sar','Escalation checklist opened');
}
function toggleStep(el){el.classList.toggle('done');el.textContent=el.classList.contains('done')?'✓':el.getAttribute('data-n');}

function openSMSModal(){
  const f=overdueFlights[0];const t=localNow();const c=window._opsSettings||{};
  document.getElementById('sms-preview-text').textContent=f
    ?`NINGALOO AVIATION SAR ALERT\n\nOVERDUE SARTIME — ${t} LOCAL\n\nAircraft: ${f.rego} (${f.aircraft||''})\nPilot: ${f.pilot}\nPhone: ${f.phone||'—'}\nRoute: ${f.dep} → ${f.dest}\nSARTIME: ${f.sartime}\nPOB: ${f.pax} pax\n\nImmediate action required.\nOps: ${c.opsPhone||'—'}`
    :`NINGALOO AVIATION SAR ALERT\nOverdue SARTIME — ${t} LOCAL`;
  document.getElementById('sms-recipients-list').innerHTML=`
    <div class="sms-recipient"><input type="checkbox" class="sms-check" checked><div><div class="sms-name">${c.opsName||'Ops Manager'}</div><div class="sms-num">${c.opsPhone||'—'}</div></div></div>
    <div class="sms-recipient"><input type="checkbox" class="sms-check" checked><div><div class="sms-name">${c.cpName||'Chief Pilot'}</div><div class="sms-num">${c.cpPhone||'—'}</div></div></div>`;
  document.getElementById('sms-sent').style.display='none';
  document.getElementById('sms-modal').classList.add('show');
}
function sendSMS(){
  document.getElementById('sms-sent').style.display='block';
  if(window._writeLog) window._writeLog('sar','SMS overdue alert dispatched');
  setTimeout(()=>closeModal('sms-modal'),2200);
}
function closeModal(id){document.getElementById(id).classList.remove('show');}

function showToast(msg,type='info'){
  const t=document.getElementById('toast');t.textContent=msg;t.className=`toast show ${type}`;
  setTimeout(()=>t.className='toast',3200);
}
window.showToast=showToast;

function exportLog(){
  const rows=document.querySelectorAll('#log-entries .log-entry');
  let txt='NINGALOO AVIATION — FLIGHTWATCH SAR LOG\nExported: '+new Date().toLocaleString()+'\n\n';
  rows.forEach(r=>{txt+=`[${r.querySelector('.log-time')?.textContent}] [${r.querySelector('.log-type')?.textContent}] ${r.querySelector('.log-msg')?.textContent}\n`;});
  const a=document.createElement('a');a.href='data:text/plain;charset=utf-8,'+encodeURIComponent(txt);a.download='NingalooSAR-Log-'+new Date().toISOString().slice(0,10)+'.txt';a.click();
}

setInterval(()=>{renderTable();renderAircraft();},30000);
</script>

</body>
</html>
